---
import Layout from "../../layouts/Layout.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter, Badge } from "@refraction-ui/astro";

const apps = [
  {
    name: "Kite AI Assistant",
    tagline: "The only AI assistant you need.",
    description: "A beautifully designed, unified assistant that gives you access to the world's most powerful frontier models like GPT-4 and Claude 3. Fast, private, and optimized to help you with your daily tasks.",
    image: "/assets/chat_mockup.png",
    badge: "Core",
    actionUrl: "https://chat.tinykite.co",
    actionLabel: "Launch App"
  },
  {
    name: "Nesta",
    tagline: "A calm family calendar.",
    description: "A beautiful, local-first family calendar that syncs over your home WiFi. No cloud, no accounts, no fuss. Perfect for a wall display or your phone.",
    image: "/assets/nesta_mockup.png",
    badge: "Lifestyle",
    actionUrl: "/nesta",
    actionLabel: "Discover Nesta"
  }
];
---

<Layout title="Apps Directory | TinyKite" description="Explore the unified TinyKite ecosystem of apps.">
  <main class="min-h-screen bg-background pt-32 pb-24 relative overflow-hidden">
    <div class="container mx-auto px-6 relative z-10">
      
      <div class="text-center mb-20 animate-fade-in-up">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 text-foreground tracking-tight">
          The App <span class="text-muted-foreground">Directory</span>
        </h1>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto leading-relaxed">
          Explore our unified family of AI assistants, beautiful mobile apps, and secure infrastructure.
        </p>
      </div>

      <!-- Premium Grid Layout with Refraction UI -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto mb-16">
        {apps.map((app, index) => (
          <div class={`animate-fade-in-up stagger-${(index % 4 + 1)} h-full`}>
            <Card class="group h-full flex flex-col overflow-hidden bg-card hover:border-border/80 transition-all duration-500 hover:shadow-lg">
              
              <!-- Image Area -->
              <div class="relative aspect-[16/9] overflow-hidden bg-black/50">
                <div class="absolute inset-0 bg-gradient-to-t from-card to-transparent z-10"></div>
                <img 
                  src={app.image} 
                  alt={app.name} 
                  class="w-full h-full object-cover transform group-hover:scale-[1.03] transition duration-700 ease-out opacity-80 group-hover:opacity-100"
                  onerror="this.src='https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop';"
                />
                <div class="absolute top-5 left-5 z-20">
                  <Badge variant="secondary" class="bg-black/60 backdrop-blur-md text-white border-white/10">
                    {app.badge}
                  </Badge>
                </div>
              </div>

              <!-- Content Area -->
              <CardHeader class="relative z-20 mt-[-2rem] pb-2">
                <CardTitle class="text-2xl tracking-tight mb-1">{app.name}</CardTitle>
                <CardDescription class="font-medium text-sm tracking-wide uppercase">{app.tagline}</CardDescription>
              </CardHeader>
              <CardContent class="flex-grow pb-8">
                <p class="text-muted-foreground text-[15px] leading-relaxed">
                  {app.description}
                </p>
              </CardContent>

              <!-- Dynamic Action Links -->
              <CardFooter class="mt-auto">
                <a href={app.actionUrl} class="inline-flex items-center gap-2 font-medium text-sm text-foreground hover:text-muted-foreground transition-colors">
                  {app.actionLabel}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
              </CardFooter>
            </Card>
          </div>
        ))}
      </div>

    </div>
  </main>
</Layout>
