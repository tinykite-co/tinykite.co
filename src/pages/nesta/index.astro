---
import Layout from "../../layouts/Layout.astro";
import catalog from "../../data/nesta/features.json";

const { product, videoBase, parts } = catalog;
---

<Layout
  title={`${product.name} — ${product.tagline}`}
  description={product.dek}
  image={product.icon}
>
  <main class="min-h-screen bg-background nesta-page">
    <!-- Hero -->
    <section class="relative pt-32 pb-16 px-6 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-[#e85d2f]/5 via-transparent to-transparent pointer-events-none"></div>
      <div class="container mx-auto max-w-4xl text-center relative z-10">
        <img
          src={product.icon}
          alt="Nesta app icon"
          width="96"
          height="96"
          class="mx-auto mb-6 rounded-[22.5%] shadow-lg"
        />
        <h1 class="text-5xl md:text-7xl font-bold mb-6 text-text" style="font-family: 'Lora', serif;">
          {product.name.toLowerCase()}<span class="text-[var(--nesta-ember)]">.</span>
        </h1>
        <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed mb-4">
          {product.tagline}
        </p>
        <p class="text-gray-500 text-base max-w-2xl mx-auto mb-8">
          {product.dek}
        </p>
        <a
          href={product.appUrl}
          class="inline-block px-8 py-3 rounded-full bg-[var(--nesta-ember)] text-white font-semibold hover:opacity-90 transition-opacity"
        >
          Open Nesta in your browser
        </a>
        <p class="text-gray-500 text-sm mt-4">
          Also on Google Play and iOS TestFlight.
        </p>
      </div>
    </section>

    <!-- Feature catalog, in the order a family meets it -->
    <section class="py-12 px-6">
      <div class="container mx-auto max-w-5xl">
        <div class="text-center mb-4">
          <h2 class="text-3xl md:text-4xl font-bold text-text mb-4" style="font-family: 'Lora', serif;">
            Everything Nesta does, in the order a family meets it
          </h2>
          <p class="text-gray-600 dark:text-gray-400 text-lg max-w-xl mx-auto">
            {product.note}
          </p>
        </div>

        <!-- Platform switcher: swaps every demo video between the Android and
             iPhone captures. -->
        <div class="flex justify-center mb-12">
          <div
            role="tablist"
            aria-label="Preview platform"
            class="inline-flex rounded-full border border-gray-200 dark:border-white/[0.1] p-1 bg-white dark:bg-white/[0.03]"
          >
            <button
              type="button"
              role="tab"
              data-platform="android"
              aria-selected="true"
              class="platform-tab px-6 py-2 rounded-full text-sm font-medium transition-colors"
            >
              Android
            </button>
            <button
              type="button"
              role="tab"
              data-platform="ios"
              aria-selected="false"
              class="platform-tab px-6 py-2 rounded-full text-sm font-medium transition-colors"
            >
              iPhone
            </button>
          </div>
        </div>

        {parts.map((part) => (
          <div class="mt-16">
            <p class="text-[var(--nesta-ember)] font-medium tracking-wide uppercase text-sm mb-2">
              {part.kicker}
            </p>
            <h3 class="text-2xl md:text-3xl font-bold text-text mb-2" style="font-family: 'Lora', serif;">
              {part.title}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 max-w-2xl mb-8">{part.dek}</p>

            <div class="flex flex-col gap-6">
              {part.features.map((feature) => (
                <article
                  id={`feature-${feature.number}`}
                  class="rounded-2xl border p-6 bg-white dark:bg-white/[0.03] border-gray-100 dark:border-white/[0.06]"
                >
                  <div class="flex flex-col sm:flex-row gap-6">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start gap-4">
                        <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-[#e85d2f]/10 text-[var(--nesta-ember)] flex items-center justify-center text-sm font-bold">
                          {feature.number.toString().padStart(2, "0")}
                        </span>
                        <div class="min-w-0">
                          <h4 class="text-text font-semibold text-lg mb-2 leading-snug">
                            {feature.title}
                          </h4>
                          <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-3">
                            {feature.summary}
                          </p>
                          <p class="inline-block text-xs px-2.5 py-1 rounded-full bg-gray-100 dark:bg-white/[0.06] text-gray-600 dark:text-gray-400">
                            {feature.entry}
                          </p>
                        </div>
                      </div>
                    </div>
                    {feature.video && (
                      <video
                        class="demo-video w-full sm:w-56 flex-shrink-0 rounded-xl border border-gray-100 dark:border-white/[0.06] bg-black"
                        controls
                        muted
                        playsinline
                        preload="metadata"
                        data-base={videoBase}
                        data-video={feature.video}
                        src={`${videoBase}android_${feature.video}`}
                      ></video>
                    )}
                  </div>
                </article>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="py-20 px-6 text-center">
      <div class="container mx-auto max-w-2xl">
        <h2 class="text-3xl font-bold text-text mb-4" style="font-family: 'Lora', serif;">
          One household. Nothing else.
        </h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8">
          No public feed, no strangers, no ads — and children never need an
          email or a password.
        </p>
        <a
          href={product.appUrl}
          class="inline-block px-8 py-3 rounded-full bg-[var(--nesta-ember)] text-white font-semibold hover:opacity-90 transition-opacity"
        >
          Get started at nesta.tinykite.co
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Nesta's brand accent is the app icon's ember — scoped to this page so
     the site-wide primary token stays untouched. */
  .nesta-page {
    --nesta-ember: #e85d2f;
  }
  .platform-tab {
    color: rgb(107 114 128);
  }
  .platform-tab.is-active {
    background: var(--nesta-ember);
    color: #fff;
  }
</style>

<script is:inline>
  (function () {
    const KEY = "nesta-demo-platform";
    const tabs = Array.from(document.querySelectorAll(".platform-tab"));
    const videos = Array.from(document.querySelectorAll("video.demo-video"));
    const stored = localStorage.getItem(KEY);
    function detectDefault() {
      if (stored === "ios" || stored === "android") return stored;
      const ua = navigator.userAgent || "";
      if (/Android/i.test(ua)) return "android";
      if (/iPhone|iPad|iPod/i.test(ua)) return "ios";
      if (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1) return "ios";
      return "android";
    }
    let platform = detectDefault();

    function apply(next) {
      platform = next;
      localStorage.setItem(KEY, next);
      tabs.forEach((tab) => {
        const active = tab.dataset.platform === next;
        tab.classList.toggle("is-active", active);
        tab.setAttribute("aria-selected", active ? "true" : "false");
      });
      videos.forEach((video) => {
        video.pause();
        video.setAttribute("src", video.dataset.base + next + "_" + video.dataset.video);
        video.load();
      });
    }

    tabs.forEach((tab) =>
      tab.addEventListener("click", () => apply(tab.dataset.platform)),
    );
    apply(platform);
  })();
</script>
