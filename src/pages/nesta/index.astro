---
import Layout from "../../layouts/Layout.astro";
import features from "../../data/nesta/features.json";
---

<Layout
  title="Nesta — A Calm Family Calendar"
  description="A local-first family calendar that syncs over your home WiFi. No cloud, no accounts, no fuss."
>
  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 px-6 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-amber-900/10 via-transparent to-transparent pointer-events-none"></div>
      <div class="container mx-auto max-w-4xl text-center relative z-10">
        <p class="text-amber-400 font-medium tracking-wide uppercase text-sm mb-4">Introducing</p>
        <h1 class="text-5xl md:text-7xl font-bold mb-6 text-white" style="font-family: 'Lora', serif;">
          Nesta
        </h1>
        <p class="text-xl md:text-2xl text-gray-400 max-w-2xl mx-auto leading-relaxed mb-4">
          A calm, local-first family calendar that syncs over your home WiFi.
        </p>
        <p class="text-gray-500 text-base max-w-xl mx-auto">
          One paper-like display on your kitchen wall — or on every phone in the house. No cloud, no accounts, no fuss.
        </p>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="py-16 px-6">
      <div class="container mx-auto max-w-6xl">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: 'Lora', serif;">
            Everything your family needs
          </h2>
          <p class="text-gray-400 text-lg max-w-xl mx-auto">
            Twelve thoughtful features, each designed to make family scheduling feel effortless.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {features.map((feature, index) => (
            <a
              href={`/nesta/${feature.slug}`}
              class:list={[
                "group relative block p-6 rounded-2xl border transition-all duration-300",
                "bg-white/[0.03] border-white/[0.06] hover:border-amber-400/30 hover:bg-white/[0.06]",
              ]}
            >
              <div class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-amber-400/10 text-amber-400 flex items-center justify-center text-sm font-bold">
                  {(index + 1).toString().padStart(2, "0")}
                </span>
                <div class="min-w-0">
                  <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-amber-300 transition-colors leading-snug">
                    {feature.title}
                  </h3>
                  <p class="text-gray-400 text-sm leading-relaxed">
                    {feature.summary}
                  </p>
                </div>
              </div>
              <div class="mt-4 ml-12 flex items-center gap-1 text-amber-400/60 group-hover:text-amber-400 text-sm transition-colors">
                <span>Read more</span>
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="py-20 px-6">
      <div class="container mx-auto max-w-2xl text-center">
        <div class="p-8 rounded-3xl border border-white/[0.06] bg-white/[0.02]">
          <h3 class="text-2xl font-bold text-white mb-3" style="font-family: 'Lora', serif;">
            Coming soon
          </h3>
          <p class="text-gray-400 mb-6">
            Nesta is in active development. Follow us for launch updates.
          </p>
          <a
            href="/contact"
            class="inline-block px-8 py-3 bg-amber-400 text-black font-semibold rounded-full hover:bg-amber-300 transition-colors text-sm"
          >
            Get in touch
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
