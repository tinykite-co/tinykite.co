---
import Layout from "../../layouts/Layout.astro";
import features from "../../data/nesta/features.json";

export function getStaticPaths() {
  return features.map((feature) => ({
    params: { feature: feature.slug },
    props: { feature },
  }));
}

interface FeatureData {
  slug: string;
  title: string;
  summary: string;
}

const { feature } = Astro.props as { feature: FeatureData };

// Read the markdown file for this feature
const featureFiles = import.meta.glob<string>(
  "../../data/nesta/features/*.md",
  { query: "?raw", import: "default" }
);

const filePath = `../../data/nesta/features/${feature.slug}.md`;
const rawContent = featureFiles[filePath]
  ? await featureFiles[filePath]()
  : "";

// Parse the markdown into sections
function parseFeatureContent(markdown: string) {
  // Remove the H1 title (we render it separately)
  const withoutTitle = markdown.replace(/^#\s+.+\n/, "");

  // Split into segments around the video directive
  const segments: Array<{ type: "text" | "video"; content: string }> = [];
  const lines = withoutTitle.split("\n");
  let currentText = "";

  for (const line of lines) {
    const videoMatch = line.match(/^::video\[(.+)\]$/);
    if (videoMatch) {
      if (currentText.trim()) {
        segments.push({ type: "text", content: currentText.trim() });
        currentText = "";
      }
      segments.push({ type: "video", content: videoMatch[1] ?? "" });
    } else {
      currentText += line + "\n";
    }
  }
  if (currentText.trim()) {
    segments.push({ type: "text", content: currentText.trim() });
  }

  return segments;
}

// Simple markdown-to-HTML converter for the subset we use
function markdownToHtml(text: string): string {
  let html = text;

  // Convert ## headings
  html = html.replace(
    /^## (.+)$/gm,
    '<h2 class="text-2xl font-bold text-white mt-12 mb-4" style="font-family: \'Lora\', serif;">$1</h2>'
  );

  // Convert bold
  html = html.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");

  // Convert unordered list items
  html = html.replace(
    /^- (.+)$/gm,
    '<li class="flex items-start gap-3"><span class="flex-shrink-0 w-1.5 h-1.5 rounded-full bg-amber-400 mt-2.5"></span><span>$1</span></li>'
  );

  // Wrap consecutive <li> elements in <ul>
  html = html.replace(
    /(<li class="flex[\s\S]*?<\/li>\n?)+/g,
    (match) =>
      `<ul class="space-y-3 text-gray-300 leading-relaxed">${match}</ul>`
  );

  // Convert paragraphs (lines that aren't headings, lists, or empty)
  html = html.replace(
    /^(?!<[hul])((?!^\s*$).+)$/gm,
    '<p class="text-gray-300 leading-relaxed mb-4">$1</p>'
  );

  // Clean up extra paragraph spacing
  html = html.replace(/\n{3,}/g, "\n\n");

  return html;
}

const segments = parseFeatureContent(rawContent);

// Find current feature index for prev/next navigation
const currentIndex = features.findIndex((f) => f.slug === feature.slug);
const previousFeature = currentIndex > 0 ? features[currentIndex - 1] : null;
const nextFeature =
  currentIndex < features.length - 1 ? features[currentIndex + 1] : null;
---

<Layout title={`${feature.title} — Nesta`} description={feature.summary}>
  <main class="min-h-screen">
    <!-- Back Navigation -->
    <div class="pt-28 px-6">
      <div class="container mx-auto max-w-3xl">
        <a
          href="/nesta"
          class="inline-flex items-center gap-2 text-gray-400 hover:text-amber-400 transition-colors text-sm"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          All Nesta features
        </a>
      </div>
    </div>

    <!-- Feature Content -->
    <article class="py-12 px-6">
      <div class="container mx-auto max-w-3xl">
        <!-- Feature number and title -->
        <div class="mb-10">
          <span
            class="inline-block px-3 py-1 rounded-full bg-amber-400/10 text-amber-400 text-sm font-medium mb-4"
          >
            Feature {(currentIndex + 1).toString().padStart(2, "0")} of {
              features.length
            }
          </span>
          <h1
            class="text-4xl md:text-5xl font-bold text-white leading-tight"
            style="font-family: 'Lora', serif;"
          >
            {feature.title}
          </h1>
        </div>

        <!-- Rendered content -->
        <div class="prose-nesta">
          {
            segments.map((segment) =>
              segment.type === "video" ? (
                <div class="my-10 rounded-2xl overflow-hidden border border-white/[0.06] bg-white/[0.02]">
                  <div class="aspect-video flex items-center justify-center bg-black/40">
                    <video
                      class="w-full h-full object-cover"
                      controls
                      preload="none"
                      poster=""
                    >
                      <source src={segment.content} type="video/mp4" />
                      <p class="text-gray-500 text-sm p-8 text-center">
                        Video demo will be available soon.
                      </p>
                    </video>
                  </div>
                </div>
              ) : (
                <Fragment set:html={markdownToHtml(segment.content)} />
              )
            )
          }
        </div>

        <!-- Prev/Next Navigation -->
        <nav
          class="mt-16 pt-8 border-t border-white/[0.06] grid grid-cols-1 md:grid-cols-2 gap-4"
        >
          {
            previousFeature ? (
              <a
                href={`/nesta/${previousFeature.slug}`}
                class="group p-5 rounded-xl border border-white/[0.06] hover:border-amber-400/30 bg-white/[0.02] hover:bg-white/[0.04] transition-all"
              >
                <span class="text-gray-500 text-sm">Previous</span>
                <p class="text-white font-medium mt-1 group-hover:text-amber-300 transition-colors">
                  {previousFeature.title}
                </p>
              </a>
            ) : (
              <div />
            )
          }
          {
            nextFeature && (
              <a
                href={`/nesta/${nextFeature.slug}`}
                class="group p-5 rounded-xl border border-white/[0.06] hover:border-amber-400/30 bg-white/[0.02] hover:bg-white/[0.04] transition-all text-right"
              >
                <span class="text-gray-500 text-sm">Next</span>
                <p class="text-white font-medium mt-1 group-hover:text-amber-300 transition-colors">
                  {nextFeature.title}
                </p>
              </a>
            )
          }
        </nav>
      </div>
    </article>
  </main>
</Layout>
