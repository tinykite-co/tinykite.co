---
import { Footer } from "@refraction-ui/astro";

const currentYear = new Date().getFullYear();

const columns = [
  {
    title: "Product",
    links: [
      { label: "Directory", href: "/apps" },
      { label: "Utilities", href: "/tools" },
      { label: "Router Hub", href: "/router" },
      { label: "Nesta", href: "/nesta" }
    ]
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "/#about" },
      { label: "Contact", href: "/contact" },
      { label: "Brand Assets", href: "/branding" }
    ]
  },
  {
    title: "Legal",
    links: [
      { label: "Privacy Policy", href: "/privacy" },
      { label: "Terms of Service", href: "/terms" },
      { label: "Company No. 16825578", href: "#" }
    ]
  }
];

const copyright = `© ${currentYear} tinykite Ltd. All rights reserved.`;
---

<div class="bg-background border-t border-border">
  <div class="mx-auto max-w-7xl px-4 pt-12">
    <a href="/" class="flex items-center gap-2 mb-4">
      <img src="/icon.png" alt="tinykite Logo" class="w-8 h-8 rounded-lg" />
      <span class="font-bold text-text text-xl tracking-tight" style="font-family: 'Nunito', sans-serif;">tinykite</span>
    </a>
    <p class="text-gray-500 text-sm max-w-sm mb-4">
      Building the future of digital interaction. Simple, elegant, and powerful tools for the modern world.
    </p>
  </div>
  <Footer columns={columns} copyright={copyright} />
</div>
