---
const apps = [
  {
    name: "Nesta",
    tagline: "Your family's private messenger.",
    description: "A private messenger for one household — no public feed, no strangers, no ads. Grown-ups hold the keys; children join with a parent-issued QR and never need an email or a password.",
    icon: "/nesta/icon-512.png",
    accent: "#e85d2f",
    badge: "Lifestyle",
    actionUrl: "/nesta",
    actionLabel: "Discover Nesta"
  },
  {
    name: "Gloss",
    tagline: "The word from your book — made clear in a breath.",
    description: "A calm, offline-first reading companion. Type a few letters (or say the word), get one short meaning with a picture or motion, and get back to the book. No account, no ads, no tracking.",
    icon: "/gloss/icon-512.png",
    accent: "#2f9e8f",
    badge: "Education",
    actionUrl: "/gloss",
    actionLabel: "Discover Gloss"
  },
  {
    name: "TinyKite Router",
    tagline: "Your family's central AI hub.",
    description: "Manage access, set usage limits, and securely store API keys for your entire family in one centralized dashboard. Pay only for exactly what you use—no hidden fees, no redundant monthly subscriptions.",
    icon: "/assets/router_icon.png",
    accent: "#3b6ff5",
    badge: "Infrastructure",
    actionUrl: "/router",
    actionLabel: "Manage Hub"
  },
  {
    name: "TinyKite Water",
    tagline: "Your friendly desktop hydration buddy.",
    description: "TinyKite Water lives quietly in your macOS menu bar and walks across your screen to remind you to drink water. Fully customizable, completely free, and offline-first.",
    icon: "/water/avatar.svg",
    accent: "#4dabf7",
    badge: "Utility",
    actionUrl: "/water",
    actionLabel: "Discover Water"
  }
];
---

<section id="apps" class="py-32 bg-[#09090b] relative overflow-hidden border-t border-white/5">
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-20 animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white tracking-tight">
        The TinyKite <span class="text-gray-500">Ecosystem</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed">
        Explore our unified family of AI assistants, beautiful mobile apps, and secure infrastructure.
      </p>
    </div>

    <!-- Premium Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto mb-16">
      {apps.map((app, index) => (
        <div class={`animate-fade-in-up stagger-${(index % 4 + 1)}`}>
          <div class="group relative h-full bg-[#111113] rounded-3xl border border-white/10 overflow-hidden hover:border-white/30 transition-all duration-500 flex flex-col hover:shadow-[0_8px_32px_rgba(255,255,255,0.05)]">
            
            <!-- Logo Area: the app's own icon on a branded glow -->
            <div
              class="relative aspect-[16/10] overflow-hidden flex items-center justify-center bg-[#0c0c0e]"
              style={`background-image: radial-gradient(115% 90% at 50% 22%, ${app.accent}30, transparent 68%);`}
            >
              <img
                src={app.icon}
                alt={`${app.name} logo`}
                width="120"
                height="120"
                class="w-[120px] h-[120px] rounded-[24%] shadow-2xl ring-1 ring-white/10 transform group-hover:scale-105 transition duration-500 ease-out"
              />
              <div class="absolute top-5 left-5 z-20">
                <span class="inline-block px-3 py-1 rounded-full bg-black/60 backdrop-blur-md text-white text-xs font-medium border border-white/10">
                  {app.badge}
                </span>
              </div>
            </div>

            <!-- Content Area -->
            <div class="p-8 flex flex-col flex-grow relative z-20">
              <h3 class="text-2xl font-semibold tracking-tight mb-1 text-white">{app.name}</h3>
              <p class="text-gray-300 font-medium text-sm tracking-wide mb-4 uppercase">{app.tagline}</p>
              <p class="text-gray-400 text-[15px] leading-relaxed mb-8 flex-grow">
                {app.description}
              </p>

              <!-- Dynamic Action Links -->
              <div class="mt-auto">
                <a href={app.actionUrl} class="inline-flex items-center gap-2 font-medium text-sm text-white hover:text-gray-300 transition-colors">
                  {app.actionLabel}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- SEO Tools Secondary Banner -->
    <div class="max-w-4xl mx-auto text-center animate-fade-in-up stagger-4">
      <div class="p-8 rounded-2xl bg-[#111113] border border-white/10 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-left">
          <h4 class="text-xl font-semibold text-white mb-2">Need a quick utility?</h4>
          <p class="text-gray-400 text-sm">
            Check out <strong class="text-gray-200">TinyKite Tools</strong>—our free, privacy-first web utilities. We never see your data.
          </p>
        </div>
        <a href="https://tinykite.co/tools" class="shrink-0 px-6 py-3 bg-white/10 hover:bg-white/20 text-white rounded-full text-sm font-medium transition-colors border border-white/5">
          Browse Tools
        </a>
      </div>
    </div>
  </div>
</section>
