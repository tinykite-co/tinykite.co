---
const apps = [
  {
    name: "Kite AI Workspace",
    description: "The ultimate unified AI workspace. Access frontier models like GPT-4 and Claude 3 in one beautifully designed app.",
    image: "/assets/chat_mockup.png",
    badge: "Core",
    actionUrl: "https://chat.tinykite.co",
    actionLabel: "Launch App"
  },
  {
    name: "TinyKite Tools",
    description: "A premium suite of completely free, privacy-first web utilities running natively in your browser via WebAssembly.",
    image: "/assets/tools_mockup.png",
    badge: "Utilities",
    actionUrl: "https://tinykite-tools.pages.dev",
    actionLabel: "Browse Tools"
  },
  {
    name: "TinyKite Router",
    description: "The centralized hub for your family's AI usage. Manage access and API keys securely in one place.",
    image: "/assets/router_mockup.png",
    badge: "Infrastructure",
    actionUrl: "/router",
    actionLabel: "Manage Hub"
  },
  {
    name: "EasyLoops",
    description: "Next-generation pedagogical learning agents leveraging advanced WebRTC mesh networks for interactive tutoring.",
    image: "/assets/easyloops_mockup.png",
    badge: "Education",
    actionUrl: "/easyloops",
    actionLabel: "Explore Platform"
  },
  {
    name: "LearnLoop Curriculum",
    description: "An immersive digital programming course led by Lumi the magical sprite, designed for intuitive learning.",
    image: "/assets/learnloop_mockup.png",
    badge: "Course",
    actionUrl: "/learnloop",
    actionLabel: "Start Learning"
  }
];
---

<section id="apps" class="py-32 bg-[#09090b] relative overflow-hidden border-t border-white/5">
  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-20 animate-fade-in-up">
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-white tracking-tight">
        The TinyKite <span class="text-gray-500">Ecosystem</span>
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto leading-relaxed">
        Explore our unified family of AI workspaces, secure utilities, and educational platforms.
      </p>
    </div>

    <!-- Premium Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {apps.map((app, index) => (
        <div class={`animate-fade-in-up stagger-${(index % 4 + 1)}`}>
          <div class="group relative h-full bg-[#111113] rounded-3xl border border-white/10 overflow-hidden hover:border-white/30 transition-all duration-500 flex flex-col hover:shadow-[0_8px_32px_rgba(255,255,255,0.05)]">
            
            <!-- Image Area -->
            <div class="relative aspect-[16/9] overflow-hidden bg-black/50">
              <div class="absolute inset-0 bg-gradient-to-t from-[#111113] to-transparent z-10"></div>
              <img 
                src={app.image} 
                alt={app.name} 
                class="w-full h-full object-cover transform group-hover:scale-[1.03] transition duration-700 ease-out opacity-80 group-hover:opacity-100"
                onerror="this.src='https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop';"
              />
              <div class="absolute top-5 left-5 z-20">
                <span class="inline-block px-3 py-1 rounded-full bg-black/60 backdrop-blur-md text-white text-xs font-medium border border-white/10">
                  {app.badge}
                </span>
              </div>
            </div>

            <!-- Content Area -->
            <div class="p-8 flex flex-col flex-grow relative z-20 mt-[-2rem]">
              <h3 class="text-2xl font-semibold tracking-tight mb-3 text-white">{app.name}</h3>
              <p class="text-gray-400 text-[15px] leading-relaxed mb-8 flex-grow">
                {app.description}
              </p>

              <!-- Dynamic Action Links -->
              <div class="mt-auto">
                <a href={app.actionUrl} class="inline-flex items-center gap-2 font-medium text-sm text-white hover:text-gray-300 transition-colors">
                  {app.actionLabel}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
